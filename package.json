{
  "name": "edgesharp",
  "version": "0.1.0",
  "description": "Zero-cost image optimization on Cloudflare Workers via Zig WASM SIMD",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./loader": {
      "import": "./dist/loader.js",
      "types": "./dist/loader.d.ts"
    },
    "./local": {
      "import": "./dist/local.js",
      "types": "./dist/local.d.ts"
    },
    "./wasm": {
      "import": "./src/wasm/edgesharp.wasm"
    }
  },
  "scripts": {
    "dev": "pnpm run build:loader && pnpm run build:demo && wrangler dev",
    "build": "pnpm run build:loader && pnpm run build:demo",
    "build:full": "pnpm run build:wasm && pnpm run build:ts && pnpm run build:demo",
    "build:wasm": "cd wasm && ./build-wasm.sh && mkdir -p ../src/wasm && cp edgesharp.wasm ../src/wasm/",
    "build:ts": "tsc && mkdir -p dist/wasm && cp src/wasm/edgesharp.wasm dist/wasm/",
    "build:loader": "tsc -p tsconfig.loader.json",
    "build:demo": "pnpm --filter edgesharp-demo run build",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "vitest run",
    "test:node": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^25.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.78.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1"
  }
}