{
  "name": "edgesharp",
  "version": "0.1.4",
  "description": "Next.js custom image loader for edgesharp — points <Image> at a Cloudflare Worker that does the optimization on Workers + R2.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamchong/edgesharp.git"
  },
  "homepage": "https://edgesharp.teamchong.net",
  "bugs": "https://github.com/teamchong/edgesharp/issues",
  "keywords": [
    "nextjs",
    "next-image",
    "image",
    "loader",
    "cloudflare",
    "workers",
    "r2",
    "image-optimization",
    "edgesharp"
  ],
  "main": "dist/loader.js",
  "types": "dist/loader.d.ts",
  "bin": {
    "edgesharp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    }
  },
  "files": [
    "dist/loader.js",
    "dist/loader.d.ts",
    "dist/cli.js",
    "dist/og-cli.js",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build:loader && pnpm run build:cli",
    "dev": "pnpm run build:loader && pnpm run build:demo && wrangler dev",
    "dev:og": "pnpm --filter edgesharp-og run dev -- --port 8788",
    "build": "pnpm run build:loader && pnpm run build:cli && pnpm run build:demo",
    "build:full": "pnpm run build:wasm && pnpm run build:ts && pnpm run build:cli && pnpm run build:demo",
    "build:wasm": "cd wasm && ./build-wasm.sh && mkdir -p ../src/wasm && cp edgesharp.wasm ../src/wasm/",
    "build:ts": "tsc && mkdir -p dist/wasm && cp src/wasm/edgesharp.wasm dist/wasm/",
    "build:loader": "tsc -p tsconfig.loader.json",
    "build:cli": "tsc -p tsconfig.cli.json && chmod +x dist/cli.js",
    "build:demo": "pnpm --filter edgesharp-demo run build",
    "deploy": "pnpm run build && wrangler deploy && pnpm --filter edgesharp-og run deploy",
    "test": "vitest run",
    "test:node": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.14",
    "@cloudflare/workers-types": "^4.20260329.1",
    "@types/node": "^25.4.0",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.78.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "postcss@<8.5.10": "^8.5.10",
      "defu@<6.1.5": "^6.1.5",
      "undici@<7.24.0": "^7.24.0",
      "wrangler@<4.59.1": "4.59.1"
    }
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1"
  }
}